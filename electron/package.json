{
  "name": "spyde-electron",
  "version": "0.2.0-rc.3",
  "description": "SpyDE — electron frontend for the spyde Python backend",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "preview": "electron-vite preview",
    "test": "playwright test",
    "test:build": "electron-vite build && playwright test",
    "bundle:python": "node scripts/bundle-python.mjs",
    "dist": "npm run build && npm run bundle:python && electron-builder --config electron-builder.yml",
    "dist:dir": "npm run build && npm run bundle:python && electron-builder --dir --config electron-builder.yml"
  },
  "dependencies": {
    "dompurify": "^3.4.12",
    "electron-updater": "^6.8.9",
    "marked": "^18.0.6",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-rnd": "^10.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0"
  }
}
